# Anthropic API key — SERVER-SIDE ONLY. Never expose this to the browser/frontend.
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides
PORT=3000

# Default model used when a module does not specify its own.
# Kept to the cheaper tier (Haiku) for cost; modules can override with Sonnet.
DEFAULT_MODEL=claude-haiku-4-5

# Default max output tokens when a module does not specify its own.
DEFAULT_MAX_TOKENS=8000

# Comma-separated allow-list for per-request `model` overrides (cost guardrail).
ALLOWED_MODELS=claude-haiku-4-5,claude-sonnet-4-6
